<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description }}">
    <meta name="keywords" content="{{ keywords }}">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
  </head>
  <body class="min-h-screen p-6 font-sans antialiased leading-snug text-black bg-white md:p-12 selection:bg-black selection:text-white {{ extraBodyClass }}">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-white focus:px-4 focus:py-2 focus:text-black focus:shadow-lg">Skip to main content</a>
    {{ bodyOpen | safe }}
    <header class="grid grid-cols-1 gap-y-8 mb-12 md:grid-cols-12 md:gap-x-12 md:mb-24">
      <div class="order-2 col-span-4 flex flex-col justify-between md:order-1 md:col-span-7 2xl:col-span-9">
        <div class="print-header hidden" aria-hidden="true">
          <div class="print-name">Jason Lau</div>
          <div class="print-subtitle">{{ printSubtitle | default("") }}</div>
        </div>
        <div class="{{ introMaxWidthClass | default('max-w-[620px]') }} text-2xl font-light leading-tight text-black intro-text">
          <h1 class="sr-only">{{ h1 }}</h1>
          <span class="font-bold">Jason Lau</span> is a
          <nav class="inline">
            {% set roles = [
              { name: "Researcher", url: "index.html" },
              { name: "Developer", url: "developer.html" },
              { name: "Designer", url: "designer.html" }
            ] %}
            {% for role in roles %}
              {%- if role.name == activeRole -%}
                <span class="role-link role-active border-b-2 border-black font-bold" aria-current="page">{{ role.name }}</span>
              {%- else -%}
                <a href="{{ role.url }}" class="role-link role-inactive border-b-2 border-gray-500 text-gray-500 hover:text-black">{{ role.name }}</a>
              {%- endif -%}
              {%- if loop.index == 1 %},
              {% elif loop.index == 2 %}, and
              {% endif -%}
            {% endfor %}</nav>,
          <span class="inline">{{ tagline | safe }}</span>
        </div>
      </div>
      <div class="order-1 col-span-4 flex justify-start -ml-[30px] -mt-5 md:order-2 md:col-span-4 md:justify-end md:ml-0 md:mt-0 xl:-mr-[50px] 2xl:col-span-2 2xl:-mr-20">
        <img src="profile-picture.png" alt="Jason Lau" width="320" height="360"
             class="h-40 w-40 object-contain md:h-auto md:w-full md:max-w-[200px]">
      </div>
      <div class="print-contact hidden" aria-hidden="true">
        <div><strong>Phone:</strong> (929) 273-1217</div>
        <div><strong>Email:</strong> i@jasonlau.io</div>
        <div><strong>GitHub:</strong> github.com/dotkrnl</div>
      </div>
      <nav aria-label="External links" class="absolute right-6 top-12 order-3 flex flex-col md:relative md:right-auto md:top-auto md:col-span-1 md:items-end md:text-right">
        <ul>
          {% set emailAddr = email | default("jalau@jumptrading.com") %}
          {% set navLinks = [
            { label: "Scholar", url: "https://scholar.google.com/citations?user=8mKFNtUAAAAJ", external: true },
            { label: "ORCID", url: "https://orcid.org/0000-0003-0751-8227", external: true },
            { label: "GitHub", url: "https://github.com/dotkrnl", external: true },
            { label: "Email", url: "mailto:" + emailAddr, external: false }
          ] %}
          {% for link in navLinks %}
          <li>
            <a href="{{ link.url }}"
               {% if link.external %}target="_blank" rel="noopener noreferrer"{% endif %}
               class="button-underline group flex items-center gap-2 md:justify-end">
              {{ link.label }}{% if link.external %}<span class="sr-only"> (opens in new tab)</span>{% endif %}
              <svg aria-hidden="true" class="h-3 w-3 opacity-0 transition-opacity group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </li>
          {% endfor %}
        </ul>
      </nav>
    </header>

    {{ content | safe }}

    <footer class="mt-24 border-t border-gray-100 pt-12 text-center md:text-left">
      <p class="text-xs uppercase tracking-widest text-gray-500">&copy; 2026 Jason Lau. Designed by Jason Lau.</p>
    </footer>
    {{ bodyClose | safe }}
  </body>
</html>
