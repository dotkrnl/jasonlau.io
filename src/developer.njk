<main id="main-content" class="grid grid-cols-1 gap-y-16 md:grid-cols-12 md:gap-x-12">
  <aside class="order-2 flex flex-col max-w-[400px] gap-16 pr-16 md:order-1 md:col-span-4 lg:-mt-[120px] xl:-mt-[140px] 2xl:col-span-3">
    <section>
      <h2 class="mb-6 text-xs font-bold uppercase tracking-[0.2em] text-gray-500">Education</h2>
      {% for edu in site.developerEducation %}
      <div{% if not loop.last %} class="mb-8"{% endif %}>
        <div class="font-bold">{{ edu.degree }}</div>
        <div class="text-gray-800">{{ edu.school }}</div>
        <div class="mt-1 text-sm text-gray-500">{{ edu.time }}</div>
        {% if edu.details %}
        {% for detail in edu.details %}
        <div class="mt-1 text-sm text-gray-500">{{ detail | safe }}</div>
        {% endfor %}
        {% endif %}
      </div>
      {% endfor %}
    </section>

    <section>
      <h2 class="mb-6 text-xs font-bold uppercase tracking-[0.2em] text-gray-500">Technical Skills</h2>
      {% for skill in site.skills %}
      <div{% if not loop.last %} class="mb-6"{% endif %}>
        <h3 class="font-bold">{{ skill.category }}</h3>
        <p class="text-sm leading-relaxed text-gray-800">{{ skill.items }}</p>
      </div>
      {% endfor %}
    </section>

    <section>
      <h2 class="mb-6 text-xs font-bold uppercase tracking-[0.2em] text-gray-500">Selected Awards</h2>
      <ul class="space-y-4 text-gray-800">
        {% for award in site.awards %}
        <li>
          <span class="block font-bold text-black">{{ award.name }}</span>
          {{ award.org }}
        </li>
        {% endfor %}
      </ul>
    </section>
  </aside>

  <div class="order-1 flex flex-col max-w-[1400px] gap-16 md:order-2 md:col-span-8 2xl:col-span-6 2xl:-mt-[140px]">
    <section class="w-full">
      <div class="mb-8 flex items-baseline justify-between border-t border-gray-100 pt-4 md:border-none md:pt-0">
        <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-gray-500">Professional Experience</h2>
      </div>
      {% for exp in experience %}
      <article class="{% if not loop.last %}mb-12{% endif %} group">
        <div class="grid grid-cols-1 gap-2 md:grid-cols-12">
          <div class="md:col-span-10">
            <h3 class="mb-1 text-lg font-bold leading-snug">{{ exp.title }}</h3>
            <div class="font-medium text-gray-800">{{ exp.org }}</div>
            <div class="mb-2 mt-1 text-sm text-gray-500">{{ exp.time }} | {{ exp.location }}</div>
          </div>
        </div>
        <div class="mt-2 text-sm leading-relaxed text-gray-800 md:pr-[16.666%]">
          <p>{{ exp.desc }}</p>
        </div>
      </article>
      {% endfor %}
    </section>

    <section class="w-full">
      <div class="mb-8 flex items-baseline justify-between border-t border-gray-100 pt-4 md:border-none md:pt-0">
        <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-gray-500">Key Engineering &amp; Systems Projects</h2>
      </div>
      <div class="space-y-10">
        {% for proj in projects %}
        <article class="group">
          <h3 class="mb-1 text-lg font-bold leading-snug">{{ proj.title }}</h3>
          <div class="mb-1 text-sm leading-snug text-gray-800">
            <span class="font-bold text-black">{{ proj.role }}</span>
          </div>
          <div class="mt-2 text-sm leading-relaxed text-gray-800 md:pr-[16.666%]">
            <p>{{ proj.desc }}</p>
          </div>
        </article>
        {% endfor %}
      </div>
    </section>
  </div>
</main>
