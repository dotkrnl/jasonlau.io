---
layout: base.njk
title: "Jason Lau - FPGA HLS Researcher"
description: "Jason Lau is a researcher interested in High-Level Synthesis, Customized Computing, and FPGA Abstraction."
keywords: "Jason Lau, Researcher, Developer, Design, HLS, High-Level Synthesis, Hardware Engineer, Jump Trading, UCLA, Tsinghua"
h1: "Jason Lau - An FPGA HLS Researcher"
printSubtitle: "FPGA HLS Researcher"
activeRole: "Researcher"
tagline: 'whose research focuses on High-Level Synthesis, Customized Computing, and FPGA Abstraction. Currently creating low-latency hardware logic at <a href="https://www.jumptrading.com" target="_blank">Jump Trading Group</a>.'
email: "lau@cs.ucla.edu"
extraBodyClass: "overflow-x-hidden"
bodyOpen: |
  <div id="app" class="relative w-full">
  <svg aria-hidden="true" class="hidden">
    <symbol id="icon-arrow-right" viewBox="0 0 24 24" fill="none" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
    </symbol>
  </svg>
permalink: "index.html"
---

{% from "macros.njk" import sectionHeading, servicesItems, reviewsSection %}
<main id="main-content" class="grid grid-cols-1 gap-y-16 md:grid-cols-12 md:gap-x-12">
  <aside class="flex flex-col max-w-[400px] gap-16 pr-16 md:col-span-4 lg:-mt-[120px] xl:-mt-[140px] 2xl:col-span-3">
    <section>
      {{ sectionHeading("Education") }}
      {% set researcherEdu = site.education | selectattr("researcher") | list %}
      {% for edu in researcherEdu %}
      <div{% if not loop.last %} class="mb-8"{% endif %}>
        <div class="font-bold">{{ edu.degree }}</div>
        <div class="text-gray-800">{{ edu.school }}</div>
        <div class="mt-1 text-sm text-gray-500">{{ edu.time }}</div>
        {% for detail in edu.details %}
        <div class="mt-1 text-sm text-gray-500">{{ detail | safe }}</div>
        {% endfor %}
      </div>
      {% endfor %}
    </section>

    <section>
      {{ sectionHeading("Experience") }}
      {% set researcherExp = site.experience | selectattr("researcher") | list %}
      {% for exp in researcherExp %}
      <article{% if not loop.last %} class="mb-8"{% endif %}>
        <h3 class="font-bold">{{ exp.title }}</h3>
        <div class="text-sm text-gray-800">{{ exp.org }}</div>
        <time class="mt-1 text-sm text-gray-500">{{ exp.time }}</time>
        <p class="mt-1 text-sm leading-relaxed text-gray-800">
          {{ exp.desc }}
        </p>
      </article>
      {% endfor %}
    </section>

    <section>
      {{ sectionHeading("Services") }}
      <ul class="list-inside space-y-2">
{{ servicesItems(site.services) }}
      </ul>
    </section>

    <section>
      {{ sectionHeading("Reviews") }}
{{ reviewsSection(site.reviews, true) }}
    </section>
  </aside>

  <div id="main-div" class="flex flex-col max-w-[1400px] gap-16 md:col-span-8 2xl:col-span-6 2xl:-mt-[140px]">
    <section class="w-full">
      <div class="mb-8 flex items-baseline justify-between border-t border-gray-100 pt-4 md:border-none md:pt-0">
        <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-gray-500">Publications (Cited 950+ times)</h2>
        <span class="hidden text-[10px] uppercase tracking-widest text-gray-500 md:block"><span class="font-black">*</span> indicates co-first authors</span>
      </div>
      <div class="space-y-12" id="publication-list">
        {% for pub in site.publications %}
        <article>
          <div class="grid grid-cols-1 gap-2 md:grid-cols-12">
            <div class="md:col-span-10">
              <h3 class="mb-1 text-lg font-bold leading-snug">
                <a href="{{ pub.pdf }}" class="paper-title button-underline group cursor-pointer"
                   data-pdf="{{ pub.pdf }}">
                  {{ pub.titleStart }}
                  <span class="whitespace-nowrap">{{ pub.titleEnd }}
                    <svg aria-hidden="true" class="inline-flex h-3 w-3 opacity-0 transition-opacity group-hover:opacity-100">
                      <use href="#icon-arrow-right"></use>
                    </svg>
                  </span>
                </a>
              </h3>
              <p class="pub-authors mb-1 text-sm leading-snug text-gray-800">{{ pub.authors | safe }}</p>
              <div class="pub-venue text-sm uppercase tracking-wide text-gray-500">{{ pub.venue | safe }}</div>
            </div>
            {% if pub.year %}
            <div class="hidden font-mono text-sm text-right text-gray-500 md:block md:col-span-2">{{ pub.year }}</div>
            {% else %}
            <div class="hidden md:block md:col-span-2"></div>
            {% endif %}
          </div>
          <div class="mt-3 text-sm leading-relaxed text-gray-800 md:pr-[16.666%]">
            <p>{{ pub.abstract }}</p>
          </div>
          {% if pub.badges %}
          <div class="mt-2">
            {% for badge in pub.badges %}
            <span class="bg-black px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-white">{{ badge }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </article>
        {% endfor %}
      </div>
    </section>
  </div>

  <section class="print-after-pubs hidden">
    <h2>Services</h2>
    <ul>
{{ servicesItems(site.services) }}
    </ul>
  </section>

  <section class="print-after-pubs hidden">
    <h2>Reviews</h2>
{{ reviewsSection(site.reviews, false) }}
  </section>
</main>

<div id="pdf-panel" role="dialog" aria-label="Paper Preview" aria-modal="true"
     class="hidden fixed inset-0 z-50 flex-col bg-white shadow-2xl lg:left-auto lg:right-0 lg:w-3/4"
     style="translate: 100% 0; transition: translate 0.3s ease-in-out">
  <div class="flex items-center justify-between border-b border-gray-200 bg-white p-4">
    <span class="text-xs font-bold uppercase tracking-widest text-gray-500">Paper Preview</span>
    <div class="flex items-center gap-4">
      <a id="download-btn" href="#" download target="_blank" rel="noopener noreferrer"
         aria-label="Download paper" class="text-gray-500 transition-colors hover:text-black">
        <svg aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
        </svg>
      </a>
      <button id="close-btn" aria-label="Close paper preview" class="text-gray-500 transition-colors hover:text-black">
        <svg aria-hidden="true" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>
  <div class="flex-grow bg-gray-50 p-4">
    <iframe id="pdf-frame" src="" title="Paper PDF viewer" class="h-full w-full border border-gray-200 bg-white"></iframe>
  </div>
</div>
</div>{# close #app #}

<script>
document.addEventListener('DOMContentLoaded', () => {
  const body = document.body;
  const pdfPanel = document.getElementById('pdf-panel');
  const pdfFrame = document.getElementById('pdf-frame');
  const downloadBtn = document.getElementById('download-btn');
  const closeBtn = document.getElementById('close-btn');
  const app = document.getElementById('app');
  const mainDiv = document.getElementById('main-div');
  const paperTitles = document.querySelectorAll('.paper-title');
  const allArticles = document.querySelectorAll('#publication-list article');
  const PANEL_TRANSITION_MS = 300;
  let triggerElement = null;

  const closePreview = () => {
    body.classList.remove('pdf-active');
    mainDiv.style.width = '';
    pdfPanel.style.translate = '100% 0';
    allArticles.forEach(art => art.classList.remove('active-paper'));
    if (triggerElement) { triggerElement.focus(); triggerElement = null; }
    setTimeout(() => {
      if (!body.classList.contains('pdf-active')) {
        pdfFrame.src = "";
        pdfPanel.classList.remove('flex');
        pdfPanel.classList.add('hidden');
      }
    }, PANEL_TRANSITION_MS);
  };

  const openPreview = (pdfUrl, titleElement) => {
    if (!pdfUrl || !pdfUrl.endsWith('.pdf')) return;
    triggerElement = titleElement;
    mainDiv.style.width = `${mainDiv.offsetWidth}px`;
    body.classList.add('pdf-active');
    pdfPanel.classList.remove('hidden');
    pdfPanel.classList.add('flex');
    requestAnimationFrame(() => {
      pdfPanel.style.translate = '0 0';
    });
    allArticles.forEach(art => art.classList.remove('active-paper'));
    const parentArticle = titleElement.closest('article');
    if (parentArticle) parentArticle.classList.add('active-paper');
    pdfFrame.src = pdfUrl;
    downloadBtn.href = pdfUrl;
    closeBtn.focus();
  };

  paperTitles.forEach(title => {
    title.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      openPreview(title.getAttribute('data-pdf'), title);
    });
  });

  closeBtn.addEventListener('click', (e) => { e.stopPropagation(); closePreview(); });
  app.addEventListener('click', () => { if (body.classList.contains('pdf-active')) closePreview(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === "Escape" && body.classList.contains('pdf-active')) closePreview();
    if (e.key === "Tab" && body.classList.contains('pdf-active')) {
      const focusable = [downloadBtn, closeBtn];
      const idx = focusable.indexOf(document.activeElement);
      if (e.shiftKey) {
        focusable[(idx <= 0 ? focusable.length : idx) - 1].focus();
      } else {
        focusable[(idx + 1) % focusable.length].focus();
      }
      e.preventDefault();
    }
  });
});
</script>
