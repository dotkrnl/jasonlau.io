---
layout: base.njk
---

{% from "macros.njk" import sectionHeading, educationList, servicesItems, reviewsSection %}
<main id="main-content" class="grid grid-cols-1 gap-y-16 md:grid-cols-12 md:gap-x-12">
  <aside class="flex flex-col md:max-w-[400px] gap-16 md:pr-16 md:col-span-4 lg:-mt-[120px] xl:-mt-[140px] 2xl:col-span-3">
    <section>
      {{ sectionHeading(pageContent.headings.education) }}
{{ educationList(siteView.education | selectattr("researcher") | list) }}
    </section>

    <section>
      {{ sectionHeading(pageContent.headings.experience) }}
      {% set researcherExp = siteView.experience | selectattr("researcher") | list %}
      {% for exp in researcherExp %}
      <article{% if not loop.last %} class="mb-8"{% endif %}>
        <h3 class="font-bold">{{ exp.title }}</h3>
        <div class="text-sm text-gray-800">{{ exp.org }}</div>
        <time class="mt-1 text-sm text-gray-500">{{ exp.time }}</time>
        <p class="mt-1 text-sm leading-relaxed text-gray-800">
          {{ exp.desc }}
        </p>
      </article>
      {% endfor %}
    </section>

    <section class="aside-print-hide">
      {{ sectionHeading(pageContent.headings.services) }}
      <ul class="list-inside space-y-2">
{{ servicesItems(siteView.services, ui) }}
      </ul>
    </section>

    <section class="aside-print-hide">
      {{ sectionHeading(pageContent.headings.reviews) }}
{{ reviewsSection(siteView.reviews, ui) }}
    </section>
  </aside>

  <div id="main-div" class="flex flex-col max-w-[1400px] gap-16 md:col-span-8 2xl:col-span-6 2xl:-mt-[140px]">
    <section class="w-full">
      <div class="mb-8 flex items-baseline justify-between border-t border-gray-100 pt-4 md:border-none md:pt-0">
        <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-gray-500">{{ pageContent.headings.publications }} ({{ pageContent.headings.citedPrefix }} {{ siteView.publicationsCitations }} {{ pageContent.headings.citedSuffix }})</h2>
        <span class="hidden text-[10px] uppercase tracking-widest text-gray-500 md:block">{{ pageContent.headings.coFirstAuthorsNote }}</span>
      </div>
      <div class="space-y-12" id="publication-list">
        {% for pub in siteView.publications %}
        <article>
          <div class="grid grid-cols-1 gap-2 md:grid-cols-12">
            <div class="md:col-span-10">
              {% if pub.translationPdf and siteView.locale == "cn" %}
              <h3 class="mb-1 text-lg font-bold leading-snug">
                <a href="{{ pub.translationPdf }}" class="paper-title button-underline group cursor-pointer"
                   data-pdf="{{ pub.translationPdf }}" data-alt-pdf="{{ pub.pdf }}">
                  {{ pub.titleStartCn }}<span class="whitespace-nowrap">{{ pub.titleEndCn }}（中文翻译）
                    <span class="paper-preview-hint">
                    <svg aria-hidden="true" class="paper-preview-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                    <span class="paper-preview-label">{{ ui.previewPdf }}</span>
                    </span>
                  </span>
                </a>
              </h3>
              <h3 class="mb-1 text-base leading-snug text-gray-600">
                <a href="{{ pub.pdf }}" class="paper-title button-underline group cursor-pointer"
                   data-pdf="{{ pub.pdf }}" data-alt-pdf="{{ pub.translationPdf }}">
                  {{ pub.titleStartEn }} <span class="whitespace-nowrap">{{ pub.titleEndEn }}
                    <span class="paper-preview-hint">
                    <svg aria-hidden="true" class="paper-preview-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                    <span class="paper-preview-label">{{ ui.previewPdf }}</span>
                    </span>
                  </span>
                </a>
              </h3>
              {% else %}
              <h3 class="mb-1 text-lg font-bold leading-snug">
                <a href="{{ pub.pdf }}" class="paper-title button-underline group cursor-pointer"
                   data-pdf="{{ pub.pdf }}">
                  {{ pub.titleStart }}{{ ui.publicationTitleSeparator }}<span class="whitespace-nowrap">{{ pub.titleEnd }}
                    <span class="paper-preview-hint">
                    <svg aria-hidden="true" class="paper-preview-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                    <span class="paper-preview-label">{{ ui.previewPdf }}</span>
                    </span>
                  </span>
                </a>
              </h3>
              {% if siteView.locale == "cn" %}
              <p class="mb-1 text-sm leading-snug text-gray-500">
                {{ pub.titleStartEn }} {{ pub.titleEndEn }}
              </p>
              {% endif %}
              {% endif %}
              <p class="pub-authors mb-1 text-sm leading-snug text-gray-800">{{ pub.authors | safe }}</p>
              <div class="pub-venue text-sm uppercase tracking-wide text-gray-500">{{ pub.venue | safe }}</div>
            </div>
            {% if pub.year %}
            <div class="hidden font-mono text-sm text-right text-gray-500 md:block md:col-span-2">{{ pub.year }}</div>
            {% else %}
            <div class="hidden md:block md:col-span-2"></div>
            {% endif %}
          </div>
          <div class="mt-3 text-sm leading-relaxed text-gray-800 md:pr-[16.666%]">
            <p>{{ pub.abstract }}</p>
          </div>
          {% if pub.badges %}
          <div class="mt-2">
            {% for badge in pub.badges %}
            <span class="bg-black px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-white">{{ badge }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </article>
        {% endfor %}
      </div>
    </section>
  </div>

  <section class="print-after-pubs hidden">
    <h2>{{ pageContent.headings.services }}</h2>
    <ul class="list-inside space-y-2">
{{ servicesItems(siteView.services, ui) }}
    </ul>
  </section>

  <section class="print-after-pubs hidden">
    <h2>{{ pageContent.headings.reviews }}</h2>
{{ reviewsSection(siteView.reviews, ui) }}
  </section>
</main>

<div id="pdf-panel" role="dialog" aria-label="{{ ui.paperPreviewDialogLabel }}" aria-modal="true"
     class="hidden fixed inset-0 z-50 flex-col bg-white shadow-2xl lg:left-auto lg:right-0 lg:w-3/4"
     style="translate: 100% 0; transition: translate 0.3s ease-in-out">
  <div class="flex items-center justify-between border-b border-gray-200 bg-white p-4">
    <span class="text-xs font-bold uppercase tracking-widest text-gray-500">{{ ui.paperPreview }}</span>
    <div class="flex items-center gap-4">
      <button id="switch-btn" class="hidden text-xs font-bold uppercase tracking-widest text-gray-500 transition-colors hover:text-black"
              data-label-original="{{ ui.switchToOriginal }}" data-label-translation="{{ ui.switchToTranslation }}">
      </button>
      <a id="download-btn" href="#" download target="_blank" rel="noopener noreferrer"
         aria-label="{{ ui.downloadPaper }}" class="text-gray-500 transition-colors hover:text-black">
        <svg aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
        </svg>
      </a>
      <button id="close-btn" aria-label="{{ ui.closePaperPreview }}" class="text-gray-500 transition-colors hover:text-black">
        <svg aria-hidden="true" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>
  <div class="flex-grow bg-gray-50 p-4">
    <iframe id="pdf-frame" src="" title="{{ ui.paperViewerTitle }}" class="h-full w-full border border-gray-200 bg-white"></iframe>
  </div>
</div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const body = document.body;
  const pdfPanel = document.getElementById('pdf-panel');
  const pdfFrame = document.getElementById('pdf-frame');
  const downloadBtn = document.getElementById('download-btn');
  const closeBtn = document.getElementById('close-btn');
  const switchBtn = document.getElementById('switch-btn');
  const app = document.getElementById('app');
  const mainDiv = document.getElementById('main-div');
  const paperTitles = document.querySelectorAll('.paper-title');
  const allArticles = document.querySelectorAll('#publication-list article');
  const PANEL_TRANSITION_MS = 300;
  let triggerElement = null;
  let currentPdf = null;
  let altPdf = null;
  let showingTranslation = false;

  const updateSwitchBtn = () => {
    if (!altPdf) {
      switchBtn.classList.add('hidden');
      return;
    }
    switchBtn.classList.remove('hidden');
    switchBtn.textContent = showingTranslation
      ? switchBtn.dataset.labelOriginal
      : switchBtn.dataset.labelTranslation;
  };

  const isTranslationPdf = (url) => url && url.endsWith('-cn.pdf');

  const getPreviewFocusables = () => [switchBtn, downloadBtn, closeBtn]
    .filter((el) => !el.classList.contains('hidden'));

  const closePreview = () => {
    body.classList.remove('pdf-active');
    mainDiv.style.width = '';
    pdfPanel.style.translate = '100% 0';
    allArticles.forEach(art => art.classList.remove('active-paper'));
    if (triggerElement) { triggerElement.focus(); triggerElement = null; }
    setTimeout(() => {
      if (!body.classList.contains('pdf-active')) {
        pdfFrame.src = "";
        pdfPanel.classList.remove('flex');
        pdfPanel.classList.add('hidden');
      }
    }, PANEL_TRANSITION_MS);
  };

  const openPreview = (pdfUrl, titleElement) => {
    if (!pdfUrl || !pdfUrl.endsWith('.pdf')) return;
    triggerElement = titleElement;
    mainDiv.style.width = `${mainDiv.offsetWidth}px`;
    body.classList.add('pdf-active');
    pdfPanel.classList.remove('hidden');
    pdfPanel.classList.add('flex');
    requestAnimationFrame(() => {
      pdfPanel.style.translate = '0 0';
    });
    allArticles.forEach(art => art.classList.remove('active-paper'));
    const parentArticle = titleElement.closest('article');
    if (parentArticle) parentArticle.classList.add('active-paper');
    currentPdf = pdfUrl;
    altPdf = titleElement.getAttribute('data-alt-pdf') || null;
    showingTranslation = isTranslationPdf(pdfUrl);
    pdfFrame.src = pdfUrl;
    downloadBtn.href = pdfUrl;
    updateSwitchBtn();
    closeBtn.focus();
  };

  switchBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const tmp = currentPdf;
    currentPdf = altPdf;
    altPdf = tmp;
    showingTranslation = !showingTranslation;
    pdfFrame.src = currentPdf;
    downloadBtn.href = currentPdf;
    updateSwitchBtn();
  });

  paperTitles.forEach(title => {
    title.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      openPreview(title.getAttribute('data-pdf'), title);
    });
  });

  closeBtn.addEventListener('click', (e) => { e.stopPropagation(); closePreview(); });
  app.addEventListener('click', () => { if (body.classList.contains('pdf-active')) closePreview(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === "Escape" && body.classList.contains('pdf-active')) closePreview();
    if (e.key === "Tab" && body.classList.contains('pdf-active')) {
      const focusable = getPreviewFocusables();
      const idx = focusable.indexOf(document.activeElement);
      if (e.shiftKey) {
        focusable[(idx <= 0 ? focusable.length : idx) - 1].focus();
      } else {
        focusable[(idx + 1) % focusable.length].focus();
      }
      e.preventDefault();
    }
  });
});
</script>
